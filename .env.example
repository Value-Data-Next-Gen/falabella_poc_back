# Torre de Control v2 — backend environment variables.
#
# Copy to .env.local (git-ignored). Production sets these in Azure App Service
# Configuration. The Settings class fails fast at import if required vars are
# missing or are placeholders.

# ============================================================
# Auth (REQUIRED — fail-fast if missing or placeholder)
# ============================================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace-me-with-48-bytes-of-random-base64
JWT_TTL_HOURS=12

# ============================================================
# Database — Azure SQL (REQUIRED)
# ============================================================
DB_SERVER=tcp:adinf.database.windows.net,1433
DB_NAME=adinf
DB_USER=administrador
DB_PASSWORD=replace-me
DB_DRIVER=ODBC Driver 18 for SQL Server
DB_SCHEMA=fpoc

# ============================================================
# Twilio (REQUIRED for Phase 3 onward)
# ============================================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=replace-me
TWILIO_AUTH_TOKEN=replace-me
TWILIO_WHATSAPP_FROM=whatsapp:+56957018982
TWILIO_INBOUND_PUBLIC_URL=http://localhost:8001
TWILIO_INBOUND_VALIDATE_SIGNATURE=false

# ============================================================
# Azure OpenAI (REQUIRED for Phase 8 onward)
# ============================================================
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=replace-me
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ============================================================
# Behavior flags
# ============================================================
# When true, send_whatsapp() persists log row but does NOT call Twilio.
NOTIFICATIONS_DRY_RUN=true
NOTIFICATIONS_ENABLED=true

# CORS allowed origins (CSV).
CORS_ALLOWED_ORIGINS=http://localhost:5180,http://127.0.0.1:5180

# Initial admin password used by seed_users.py (Phase 4+). Rotate immediately.
INITIAL_ADMIN_PASSWORD=admin123

# Day-state reset disable flag (when true, the admin reset endpoint returns 403).
DAY_STATE_RESET_DISABLED=false

# ============================================================
# Observability
# ============================================================
APP_INSIGHTS_CONNECTION_STRING=
LOG_LEVEL=INFO
