# Azure SQL (adinf) — copiar a .env y completar en dev local.
# En Azure App Service, configurar estas como Application Settings.
DB_SERVER=adinf.database.windows.net,1433
DB_NAME=adinf
DB_USER=administrador
DB_PASSWORD=
DB_DRIVER=ODBC Driver 17 for SQL Server
DB_SCHEMA=fpoc

# JWT (cambiar en prod)
JWT_SECRET=dev-secret-change-me-for-prod
JWT_TTL_HOURS=12

# Twilio WhatsApp (sandbox por defecto)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Auth: preferir API Key. Si esto está, se usa.
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=
# Fallback: Auth Token del account (solo si no hay API Key).
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Content Template (opcional). Si se define, auto-notify y /test lo usan.
# Si queda vacío, se usa modo freeform body. Solo válido dentro ventana 24/72h.
TWILIO_CONTENT_SID=
NOTIFICATIONS_ENABLED=true
NOTIFICATIONS_DRY_RUN=false
