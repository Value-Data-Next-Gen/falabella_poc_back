# Azure SQL (adinf) — copiar a .env y completar en dev local.
# En Azure App Service, configurar estas como Application Settings.
#
# Azure SQL es el ÚNICO backend soportado (sin fallback local). Para dev local,
# usar túnel SSH/VPN o una Azure SQL de QA. core.db hace fail-fast al import
# si DB_SERVER no está seteada.
DB_SERVER=adinf.database.windows.net,1433
DB_NAME=adinf
DB_USER=administrador
DB_PASSWORD=
DB_DRIVER=ODBC Driver 17 for SQL Server
DB_SCHEMA=fpoc

# JWT — OBLIGATORIO setearlo (el backend hace fail-fast al import si está
# vacío o si conserva el placeholder histórico "dev-secret-change-me-for-prod").
# Generar uno random:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
JWT_TTL_HOURS=12

# Admin inicial (creado por fpoc_loader/seed_users.py). Si no se setea, se
# usa "admin123" como fallback con warning — rotar inmediatamente en prod.
INITIAL_ADMIN_PASSWORD=

# Twilio WhatsApp (sandbox por defecto)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Auth: preferir API Key. Si esto está, se usa.
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=
# Fallback: Auth Token del account (solo si no hay API Key).
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Content Template (opcional). Si se define, auto-notify y /test lo usan.
# Si queda vacío, se usa modo freeform body. Solo válido dentro ventana 24/72h.
TWILIO_CONTENT_SID=

# Templates de WhatsApp aprobados por Meta (UTILITY). Estos son OVERRIDES;
# si quedan vacíos, cada call site usa el SID hardcoded como fallback. Los IDs
# de abajo son los aprobados al 2026-05-20 en el sender +15559320722.
# vd_alerta_motivo_v2 — 6 vars (severidad, motivo, vehiculo, conductor, cliente, comentario)
TWILIO_CONTENT_SID_ALERTA_MOTIVO=HX6821f9cad06ce1980bee5ad410006e43
# vd_vip_deadline_v2 — 6 vars (cliente, deadline, mins_left, vehiculo, eta, slack)
TWILIO_CONTENT_SID_VIP_DEADLINE=HX679d07e0eb57dec69f27ef169adee32e
# vd_invitacion — 1 var (nombre)
TWILIO_CONTENT_SID_INVITACION=HXb810bbcc6365876cdade57471d7f85ca
# vd_revision_ia_v2 — 2 vars (motivo_reportado, motivo_sugerido)
TWILIO_CONTENT_SID_REVISION_IA=HXd49ad45c3dc35c4aa131ebcf3ab8522e
# vd_cuenta_activada — 1 var (nombre); usado en activación de cuenta WhatsApp.
TWILIO_CONTENT_SID_CUENTA_ACTIVADA=HX13bdf3c0eaecfb740ec3f21760790c38
NOTIFICATIONS_ENABLED=false
NOTIFICATIONS_DRY_RUN=false

# Auto-notify (motivos alertables -> WhatsApp). 'true' para activar.
# Para activar en sandbox: ENABLE_AUTO_NOTIFY=true + NOTIFICATIONS_ENABLED=true
# + NOTIFICATIONS_DRY_RUN=false. Requiere usuario con notify_whatsapp=1 y
# phone_e164 registrados en sandbox Twilio.
ENABLE_AUTO_NOTIFY=false
# Cooldown anti-spam: segundos mínimos entre WhatsApps al mismo número.
# 300s = 5min. Protege contra ticks con N alertas que disparen N mensajes.
AUTO_NOTIFY_COOLDOWN_SEC=300

# Azure OpenAI — classifier de motivos del notebook auditoria_llm_directo.
# Si faltan, el endpoint /api/motivos/classify cae a fallback por keywords.


AZURE_OPENAI_ENDPOINT=https://projects-vdata.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-key-here
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-12-01-preview
